<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Força HTTP -> HTTPS (requer o módulo URL Rewrite no IIS) -->
    <rewrite>
      <rules>
        <rule name="Force HTTPS" enabled="true" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- Evita listagem de diretórios -->
    <directoryBrowse enabled="false" />

    <!-- Bloqueia acesso direto à pasta /back -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="back" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
